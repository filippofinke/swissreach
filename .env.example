# ──────────────────────────────────────────────────────────────────────────────
# Environment variables used by the build scripts (scripts/*.ts).
# Copy this file to .env and uncomment/modify the values you need.
# None of these are required — sensible defaults are used when unset.
# ──────────────────────────────────────────────────────────────────────────────

# Number of service days to build (default: 14 for sample, 1 for real)
# DAYS=14

# Override the Swiss GTFS download URL
# GTFS_URL=https://data.opentransportdata.swiss/en/dataset/timetable-2026-gtfs2020/permalink

# Force re-download of the GTFS feed even if swiss-gtfs.zip already exists
# FRESH=1

# Default origin station source ID shown on first load
# DEFAULT_ORIGIN=Parent8507000

# Human-readable name written to meta.json
# FEED_NAME=Swiss public transport

# Override the SBB logo SVG URL (trademark, fetched by `npm run logo`)
# SBB_LOGO_URL=https://upload.wikimedia.org/wikipedia/commons/2/23/SBB_logo_simplified.svg

# Vite base path for GitHub Pages sub-path deployment (set by CI)
# BASE_PATH=/isochrone/
